<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>S2Socket Chat</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@0.9.3/css/bulma.min.css">
    <link rel="stylesheet" href="/public/css/styles.css">
</head>

<body class="is-mobile">
    <div class="container is-vcentered">
        <div class="columns is-centered">
            <!-- Left Column for Chat and Input -->
            <div id="chat-box" class="column is-half box">
                <h1 id="title">RealTimeChat</h1>   
                <div id="chat-container" class="box">
                    <ul id="messages" class="content"></ul>
                </div>

                <form id="form" class="field has-addons">
                    <div class="control is-expanded">
                        <input id="input" class="input" autocomplete="off" required />
                    </div>
                    <div class="control">
                        <button id="sendMessage" class="button is-primary"><i class="fa-solid fa-paper-plane"></i>
                            Send</button>
                    </div>
                </form>
            </div>

            <!-- Right Column for User Info -->
            <div class="column is-one-quarter">
                <div class="wrapper-user-info box">
                    <p>Total Users: <span id="userTotal"></span></p>
                    <ul id="userList" class="content"></ul>
                    <!-- Nova caixa para funções -->
                    <div class="user-actions">
                        <div class="user-actions">
                            <ul>
                                <li>
                                    <button id="clearMessage" class="button"><i class="fas fa-trash"></i> Clear</button>
                                </li>
                                <li>
                                    <button id="exportButton" class="button"><i class="fas fa-file-export"></i>
                                        Export</button>
                                </li>
                                <li>
                                    <button id="toggleTheme" class="button">
                                        <i class="fa-solid fa-moon"></i> Dark
                                    </button>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <!-- <script src="/public/js/index.js"></script> -->
    <script src="/public/js/script.js"></script>
</body>

</html>